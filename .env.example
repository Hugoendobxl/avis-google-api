# PostgreSQL (Railway — auto-provisioned)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Google OAuth 2.0 (Business Profile API)
# Reuse credentials from Railway project modest-unity (cabinet-finance-api)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_BUSINESS_LOCATION_ID=

# Anthropic API (for AI draft generation)
ANTHROPIC_API_KEY=

# CORS (frontend post-traitement URL)
CORS_ORIGIN=https://post-traitement.vercel.app

# Cron schedule for reviews sync (default: daily 06:00 UTC)
SYNC_CRON=0 6 * * *

# Server
PORT=3000
